---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import signboard from '../assets/characters/signboard_questionlab.png';

const posts = (await getCollection('blog')).filter(
  (post) => post.data.status === 'published',
);

const originSeries = posts
  .filter((p) => p.data.series === '질문연구소는 이렇게 시작되었습니다')
  .sort((a, b) => (a.data.seriesNumber ?? 0) - (b.data.seriesNumber ?? 0));

const devlogSeries = posts
  .filter((p) => p.data.series === '질문연구소 개발일지')
  .sort((a, b) => (a.data.seriesNumber ?? 0) - (b.data.seriesNumber ?? 0));
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        text-align: center;
        padding: 2em 0 1em;
      }
      .signboard {
        border-radius: 12px;
        margin-bottom: 1.2em;
      }
      .hero h1 {
        font-size: 2em;
        margin-bottom: 0.3em;
        word-break: keep-all;
      }
      .hero p {
        color: rgb(var(--gray));
        font-size: 1.1em;
        max-width: 500px;
        margin: 0 auto;
        line-height: 1.7;
      }
      .section {
        margin-top: 3em;
      }
      .section-title {
        font-size: 1.3em;
        margin-bottom: 1em;
        padding-bottom: 0.5em;
        border-bottom: 2px solid var(--accent);
        display: inline-block;
      }
      .series-list {
        list-style: none;
        padding: 0;
        margin: 0;
        counter-reset: series;
      }
      .series-item {
        counter-increment: series;
        padding: 0.8em 0;
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      .series-item a {
        text-decoration: none;
        color: rgb(var(--gray-dark));
        display: flex;
        align-items: baseline;
        gap: 0.8em;
      }
      .series-item a:hover {
        color: var(--accent);
      }
      .series-num {
        font-size: 0.85em;
        color: var(--accent);
        font-weight: 700;
        min-width: 2em;
      }
      .series-title {
        font-weight: 500;
      }
      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .post-item {
        padding: 1em 0;
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      .post-item a {
        text-decoration: none;
        color: inherit;
      }
      .post-item a:hover .post-title {
        color: var(--accent);
      }
      .post-title {
        font-size: 1.1em;
        font-weight: 600;
        margin: 0.2em 0;
        transition: color 0.2s;
        word-break: keep-all;
      }
      .post-meta {
        display: flex;
        align-items: center;
        gap: 0.5em;
        font-size: 0.8em;
        color: rgb(var(--gray));
      }
      .post-meta .dot { opacity: 0.4; }
      .view-all {
        display: inline-block;
        margin-top: 1.5em;
        color: var(--accent);
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="hero">
        <Image src={signboard} alt="질문연구소 간판" width={360} class="signboard" />
        <h1>질문연구소 블로그</h1>
        <p>AI 시대, 아이들에게 필요한 건 좋은 질문을 하는 힘.<br />그 여정을 기록합니다.</p>
      </div>

      {originSeries.length > 0 && (
        <section class="section">
          <h2 class="section-title">질문연구소는 이렇게 시작되었습니다</h2>
          <ol class="series-list">
            {originSeries.map((post) => (
              <li class="series-item">
                <a href={`/blog/${post.id}/`}>
                  <span class="series-num">{post.data.seriesNumber}편</span>
                  <span class="series-title">{post.data.title}</span>
                </a>
              </li>
            ))}
          </ol>
        </section>
      )}

      {devlogSeries.length > 0 && (
        <section class="section">
          <h2 class="section-title">질문연구소 개발일지</h2>
          <ol class="series-list">
            {devlogSeries.map((post) => (
              <li class="series-item">
                <a href={`/blog/${post.id}/`}>
                  <span class="series-num">{post.data.seriesNumber}편</span>
                  <span class="series-title">{post.data.title}</span>
                </a>
              </li>
            ))}
          </ol>
        </section>
      )}

      <a href="/blog" class="view-all">모든 글 보기 &rarr;</a>
    </main>
    <Footer />
  </body>
</html>
