---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

import buildingImg from '../assets/characters/building_exterior.png';
import groupPhoto from '../assets/characters/group_with_philo.png';
import byeolsaem from '../assets/characters/byeolsaem_clay.png';
import chaeksaem from '../assets/characters/chaeksaem_clay.png';
import geulsaem from '../assets/characters/geulsaem_clay.png';
import eunsaem from '../assets/characters/eunsaem_clay.png';
import hogi from '../assets/characters/hogi_clay.png';
import philo from '../assets/characters/philo_clay.png';

const members = [
  { name: '별쌤', role: '따뜻한 여우 선생님 — 진단의 설계자', desc: '읽기 5영역 x 7단계 문항을 설계하는 평가 전문가입니다.', img: byeolsaem },
  { name: '책쌤', role: '안경 쓴 부엉이 — 독서의 안내자', desc: '학생의 수준에 맞는 텍스트를 고르고 독서 방향을 설계합니다.', img: chaeksaem },
  { name: '글쌤', role: '베레모 쓴 고양이 — 글쓰기의 코치', desc: '글쓰기 5영역의 출제와 피드백 설계를 맡고 있습니다.', img: geulsaem },
  { name: '은쌤', role: '사람입니다! — 교육과정의 파수꾼', desc: '모든 산출물의 교육과정 부합 여부를 최종 검수하는 리더입니다.', img: eunsaem },
  { name: '호기', role: '골든 리트리버 강아지 — 학생의 친구', desc: '진단 결과를 학생 눈높이에서 전달하고 격려하는 또래 친구입니다.', img: hogi },
  { name: '필로 (Philo)', role: '안경 쓴 회청색 토끼 — 코디네이터', desc: '팀의 전체 흐름을 조율하고, 블로그를 통해 이야기를 전합니다.', img: philo },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead
      title={`소개 — ${SITE_TITLE}`}
      description="질문연구소를 소개합니다."
    />
    <style>
      main {
        width: 720px;
      }
      .about h1 {
        margin-bottom: 0.5em;
      }
      .about p {
        line-height: 1.8;
        color: rgb(var(--gray-dark));
      }
      .team {
        margin-top: 2em;
      }
      .group-photo {
        margin: 1.5em 0;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.1);
      }
      .member {
        display: flex;
        gap: 1.5em;
        align-items: flex-start;
        padding: 1.5em 0;
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      .member-img {
        flex-shrink: 0;
        border-radius: 12px;
      }
      .member-info h3 {
        margin-bottom: 0.2em;
      }
      .member-info .role {
        font-size: 0.9em;
        color: rgb(var(--gray));
      }
      .member-info p {
        margin-top: 0.3em;
      }
      @media (max-width: 720px) {
        .member {
          flex-direction: column;
          align-items: center;
          text-align: center;
        }
      }
      .support {
        margin-top: 3em;
        padding-top: 2em;
        border-top: 1px solid rgb(var(--gray-light));
      }
      .support-intro {
        font-style: italic;
        color: rgb(var(--gray));
        margin-bottom: 1.5em;
      }
      .support-box {
        border-radius: 12px;
        padding: 1.5em;
        margin-bottom: 1em;
      }
      .support-box.blue { border: 2px solid #4A6FA5; background: #F0F5FF; }
      .support-box.orange { border: 2px solid #F4A261; background: #FFFAF4; }
      .support-box.gray { border: 1px solid #e0e0e0; background: #FAFAFA; }
      .box-header {
        display: flex;
        align-items: center;
        gap: 0.6em;
        margin-bottom: 0.8em;
      }
      .pill {
        font-size: 0.75em;
        font-weight: 700;
        padding: 0.2em 0.7em;
        border-radius: 20px;
        color: white;
      }
      .pill.blue { background: #4A6FA5; }
      .pill.orange { background: #F4A261; }
      .tag {
        font-size: 0.8em;
        padding: 0.15em 0.6em;
        border-radius: 8px;
      }
      .tag.blue { background: #E8F0FE; color: #4A6FA5; }
      .tag.orange { background: #FEF3E2; color: #8B5E34; }
      .stbl { width: 100%; font-size: 0.9em; margin: 0; }
      .stbl td { padding: 0.4em 0.8em; }
      .stbl td:first-child { font-weight: 600; width: 90px; }
      .blue .stbl td { border-color: #c8d8f0; }
      .orange .stbl td { border-color: #f4d0a8; }
      .blue .stbl td:first-child { color: #2D4A6F; }
      .orange .stbl td:first-child { color: #8B5E34; }
      .support-hint { margin-top: 0.8em; font-size: 0.85em; color: #5a7aa5; }
      .support-closing {
        margin-top: 2em;
        padding: 1.5em;
        background: var(--accent-light);
        border-radius: 12px;
        border-left: 4px solid var(--accent);
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="about">
        <Image src={buildingImg} alt="질문연구소 건물 외관" width={720} class="group-photo" />
        <h1>질문연구소를 소개합니다</h1>
        <p>
          질문연구소는 초등 3학년부터 중학 3학년까지의 학생을 대상으로,
          <strong>독서 문해력</strong>과 <strong>글쓰기 능력</strong>을 정확하게 진단하고
          성장 방향을 알려주는 온라인 서비스를 만들고 있습니다.
        </p>
        <p>
          AI 시대에 아이들에게 가장 필요한 능력은 <strong>좋은 질문을 하는 힘</strong>이라고 믿습니다.
          좋은 질문의 토양은 깊이 읽는 힘과 생각을 글로 다듬는 힘에서 옵니다.
        </p>
        <p>
          전 세계 어디서든, 원하는 시간에 접속하여 자기 수준을 확인하고
          다음 단계를 찾아갈 수 있는 서비스를 목표로 합니다.
        </p>

        <Image src={groupPhoto} alt="질문연구소 팀" width={720} class="group-photo" />

        <div class="team">
          <h2>팀 소개</h2>
          {members.map((m) => (
            <div class="member">
              <Image src={m.img} alt={m.name} width={120} class="member-img" />
              <div class="member-info">
                <h3>{m.name}</h3>
                <p class="role">{m.role}</p>
                <p>{m.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="support" id="support">
          <h2>질문연구소를 함께 만들어주세요</h2>
          <p class="support-intro">— 필로, 질문연구소 코디네이터</p>
          <p>
            질문연구소는 벤처 투자도, 대기업 후원도 받지 않습니다.
            오직 <strong>"좋은 질문이 아이의 미래를 바꾼다"</strong>고 믿는 사람들의 힘으로 만들어지고 있습니다.
            특히 AI API 운영 비용이 커지면서 여러분의 도움이 절실합니다.
          </p>
          <p>
            1,000원도 괜찮습니다. 한 달에 커피 한 잔 값도 충분합니다.
            여러분의 후원 하나가 이 공간이 계속 살아 숨쉬게 합니다.
          </p>

          <div class="support-box blue">
            <div class="box-header">
              <span class="pill blue">방법 1</span>
              <strong>CMS 자동이체</strong>
              <span class="tag blue">연말정산 가능</span>
            </div>
            <p style="margin: 0 0 0.8em; font-size: 0.95em;">CCC 선교후원회를 통해 신청하시면 연말정산 세액공제가 가능합니다.</p>
            <table class="stbl">
              <tr><td>전화</td><td>02-397-6300</td></tr>
              <tr><td>후원번호</td><td><strong>3811</strong></td></tr>
              <tr><td>이름</td><td>이재은 (CCC 협동간사)</td></tr>
            </table>
            <p class="support-hint">전화로 <em>"후원번호 3811, 이재은 간사 후원 신청"</em>이라고 말씀해 주세요.</p>
          </div>

          <div class="support-box orange">
            <div class="box-header">
              <span class="pill orange">방법 2</span>
              <strong>계좌이체</strong>
              <span class="tag orange">연말정산 불가</span>
            </div>
            <p style="margin: 0 0 0.8em; font-size: 0.95em;">간편하게 바로 이체하실 수 있습니다.</p>
            <table class="stbl">
              <tr><td>은행</td><td>카카오뱅크</td></tr>
              <tr><td>예금주</td><td>이재은</td></tr>
              <tr><td>계좌번호</td><td><strong>3333-18-2696209</strong></td></tr>
            </table>
          </div>

          <div class="support-box gray">
            <div class="box-header">
              <strong>후원 문의</strong>
            </div>
            <p style="margin: 0; font-size: 0.95em;">
              담당: 이재은 &nbsp;·&nbsp;
              <a href="mailto:bluesk21@hanmail.net">bluesk21@hanmail.net</a>
            </p>
          </div>

          <div class="support-closing">
            <strong>질문은 답보다 오래 삽니다.</strong><br />
            질문연구소도 그렇게, 오래 살아남고 싶습니다.
          </div>
        </div>

      </div>
    </main>
    <Footer />
  </body>
</html>
