---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
  prevPost?: { id: string; title: string };
  nextPost?: { id: string; title: string };
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  author,
  category,
  series,
  seriesNumber,
  prevPost,
  nextPost,
} = Astro.props;
---

<html lang="ko">
  <head>
    <BaseHead title={`${title} — 질문연구소 블로그`} description={description} />
    <style>
      main {
        width: calc(100% - 2em);
        max-width: 100%;
        margin: 0;
      }
      .hero-image {
        width: 100%;
      }
      .hero-image img {
        display: block;
        margin: 0 auto;
        border-radius: 12px;
        box-shadow: var(--box-shadow);
      }
      .prose {
        width: 720px;
        max-width: calc(100% - 2em);
        margin: auto;
        padding: 1em;
        color: rgb(var(--gray-dark));
      }
      .post-header {
        margin-bottom: 2em;
        padding-bottom: 1.5em;
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      .post-header h1 {
        margin: 0.3em 0 0.4em;
        line-height: 1.3;
        word-break: keep-all;
      }
      .meta {
        display: flex;
        align-items: center;
        gap: 0.8em;
        color: rgb(var(--gray));
        font-size: 0.9em;
        flex-wrap: wrap;
      }
      .meta .author {
        font-weight: 500;
        color: rgb(var(--gray-dark));
      }
      .meta .dot { opacity: 0.4; }
      .series-label {
        font-size: 0.9em;
        color: var(--accent);
        font-weight: 500;
        margin-bottom: 0.2em;
      }
      .last-updated {
        font-style: italic;
        font-size: 0.85em;
        color: rgb(var(--gray));
      }
      .series-nav {
        display: flex;
        justify-content: space-between;
        gap: 1em;
        margin-top: 3em;
        padding-top: 1.5em;
        border-top: 1px solid rgb(var(--gray-light));
        font-size: 0.9em;
      }
      .series-nav a {
        text-decoration: none;
        color: var(--accent);
        max-width: 48%;
      }
      .series-nav a:hover {
        color: var(--accent-dark);
      }
      .series-nav .label {
        display: block;
        font-size: 0.8em;
        color: rgb(var(--gray));
        margin-bottom: 0.2em;
      }
      .series-nav .next {
        text-align: right;
        margin-left: auto;
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        <div class="hero-image">
          {heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
        </div>
        <div class="prose">
          <div class="post-header">
            {series && seriesNumber && (
              <p class="series-label">{series} — {seriesNumber}편</p>
            )}
            <h1>{title}</h1>
            <div class="meta">
              <CategoryBadge category={category} />
              <span class="dot">·</span>
              <span class="author">{author}</span>
            </div>
            {updatedDate && (
              <p class="last-updated">
                마지막 수정: <FormattedDate date={updatedDate} />
              </p>
            )}
          </div>
          <slot />

          {(prevPost || nextPost) && (
            <nav class="series-nav">
              {prevPost ? (
                <a href={`/blog/${prevPost.id}/`}>
                  <span class="label">이전 글</span>
                  {prevPost.title}
                </a>
              ) : <span />}
              {nextPost ? (
                <a href={`/blog/${nextPost.id}/`} class="next">
                  <span class="label">다음 글</span>
                  {nextPost.title}
                </a>
              ) : <span />}
            </nav>
          )}
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
